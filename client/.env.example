# Copy to .env.local for local dev. Never commit .env or .env.local.

# Backend API (see client/src/config/axios.js)
REACT_APP_API_URL=http://localhost:5001

# Voice / Live interview pages use @google/genai in the browser (Interview.js, VoiceInterview.js).
# Any REACT_APP_* value is embedded in the client bundle — use a restricted dev key only, or refactor to a server proxy for production.
# REACT_APP_GEMINI_API_KEY=
