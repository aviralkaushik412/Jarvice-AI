# Copy to .env and fill in real values. Never commit .env.

# PostgreSQL (used by config/database.js)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=jarvice_ai
DB_USER=jarvice_user
DB_PASSWORD=your_database_password
# Optional: if you use a connection URL elsewhere, URL-encode special characters in the password (e.g. @ -> %40)

JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRE=7d

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=your_email@gmail.com

# Google AI (chat uses server SDK; voice uses REACT_APP_GEMINI_API_KEY in client/.env.local)
# Use a key that allows server-side Generative Language API (not "HTTP referrers only" unless you proxy).
GEMINI_API_KEY=
# Optional alias used by some SDKs
# GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

OPENAI_API_KEY=
# Set to false when OpenAI is unreachable from your network (e.g. TLS blocked)
# OPENAI_FALLBACK_ENABLED=false
# Optional: default is gpt-4o-mini
# OPENAI_CHAT_MODEL=gpt-4o-mini

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

PORT=5001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads
